# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# INSTRUCTIONS:
#   1. Copy this file and rename the copy to ".env"   (no .example extension)
#   2. Replace every placeholder value with your real value
#   3. NEVER commit .env to Git — it contains secrets
#
# To copy:
#   Windows CMD:   copy .env.example .env
#   PowerShell:    Copy-Item .env.example .env
#   Mac/Linux:     cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────


# ── OpenAI API Key ────────────────────────────────────────────────────────────
# Get this from: https://platform.openai.com/api-keys
# Replace "your-openai-api-key-here" with your actual key (starts with "sk-")
OPENAI_API_KEY=your-openai-api-key-here


# ── OpenAI Model Settings ─────────────────────────────────────────────────────
# GPT-4o-mini is cheapest and fast. Change to "gpt-4o" for better answers.
OPENAI_CHAT_MODEL=gpt-4o-mini

# Model used to convert text into vectors (numbers) for semantic search
OPENAI_EMBEDDING_MODEL=text-embedding-3-small


# ── Backend API Settings ──────────────────────────────────────────────────────
# DESKTOP: This is where FastAPI (the ML backend) runs
# On your DESKTOP, set this to: http://localhost:8000
# On your LAPTOP (accessing desktop over WiFi), set this to:
#   http://192.168.X.X:8000   ← replace with your desktop's local IP
# Find your desktop's local IP by running "ipconfig" on your desktop
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# URL your Streamlit frontend uses to reach the FastAPI backend
# If running on the same machine: http://localhost:8000
# If running frontend on laptop, backend on desktop: http://192.168.X.X:8000
BACKEND_URL=http://localhost:8000


# ── Model Settings ────────────────────────────────────────────────────────────
# Grounding DINO: open-vocabulary object detector
# "IDEA-Research/grounding-dino-tiny" is faster/smaller
# "IDEA-Research/grounding-dino-base" is more accurate but needs more VRAM
GROUNDING_DINO_MODEL=IDEA-Research/grounding-dino-tiny

# SAM2: segmentation model
# Options: "facebook/sam2-hiera-tiny" | "facebook/sam2-hiera-small" | "facebook/sam2-hiera-large"
# tiny = fastest, large = most accurate. Start with small for RTX 3080Ti.
SAM2_MODEL=facebook/sam2-hiera-small

# BLIP captioner — switch between BLIP-1 and BLIP-2 by changing the model ID
# BLIP-2 (default, better quality): Salesforce/blip2-opt-2.7b       (~6GB VRAM)
# BLIP-1 (lighter, fallback):       Salesforce/blip-image-captioning-large (~1.5GB VRAM)
BLIP_MODEL=Salesforce/blip2-opt-2.7b


# ── Hardware Settings ─────────────────────────────────────────────────────────
# "cuda" = use NVIDIA GPU (recommended for desktop with RTX 3080Ti)
# "cpu"  = use CPU only (slow but works on any machine, good for laptop)
# "auto" = let the system decide automatically (recommended default)
DEVICE=auto

# Model precision — affects speed and VRAM usage:
# "float16" = half precision: uses ~50% less VRAM, slightly less accurate (recommended)
# "float32" = full precision: uses more VRAM, slightly more accurate
MODEL_PRECISION=float16


# ── ChromaDB Settings ─────────────────────────────────────────────────────────
# Path where ChromaDB stores your tool manual embeddings on disk
# This folder is created automatically by ChromaDB on first run
CHROMA_DB_PATH=./backend/knowledge/chroma_store


# ── MLflow Settings ───────────────────────────────────────────────────────────
# Path where MLflow stores experiment logs and metrics
MLFLOW_TRACKING_URI=./mlops/tracking

# Name of your MLflow experiment (groups all runs together)
MLFLOW_EXPERIMENT_NAME=workspacevision_inference


# ── Application Settings ──────────────────────────────────────────────────────
# Maximum image size (pixels) — larger images are resized before processing
# This controls speed vs. accuracy tradeoff
MAX_IMAGE_SIZE=1024

# Video processing: how many frames per second to analyze
# 1 = analyze 1 frame per second (fast, good for MVP)
# 2 = analyze 2 frames per second (better coverage, slower)
VIDEO_FPS_PROCESS=1

# Max number of objects to detect per image (prevents too many results)
MAX_DETECTIONS=10

# Confidence threshold: only show detections above this score (0.0 to 1.0)
# 0.3 = show detections with >30% confidence
DETECTION_CONFIDENCE_THRESHOLD=0.3

# Log level for backend (DEBUG shows everything, INFO shows important events only)
LOG_LEVEL=INFO
