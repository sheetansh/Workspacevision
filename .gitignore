# .gitignore
# ─────────────────────────────────────────────────────────────────────────────
# Git ignores everything listed here — these files/folders are NOT uploaded
# to GitHub. Reasons: secrets, large files, auto-generated code, OS junk.
# ─────────────────────────────────────────────────────────────────────────────


# ── SECRETS — Never commit these ─────────────────────────────────────────────
.env                  # Your real API keys live here — NEVER share this file


# ── VIRTUAL ENVIRONMENT — Large, machine-specific, never commit ───────────────
venv/
.venv/
env/
ENV/


# ── PYTHON CACHE — Auto-generated bytecode files, not needed in Git ──────────
__pycache__/
*.py[cod]             # Matches .pyc .pyo .pyd files
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg


# ── ML MODEL WEIGHTS — Huge files (100MB–10GB), never commit to Git ──────────
# Models download automatically from HuggingFace on first run
*.pt                  # PyTorch model files
*.pth                 # PyTorch checkpoint files
*.bin                 # HuggingFace model binaries
*.safetensors         # HuggingFace SafeTensors format
models/weights/       # Any local weight folder


# ── MLFLOW TRACKING — Auto-generated logs, not needed in Git ─────────────────
mlops/tracking/
mlruns/


# ── CHROMADB — Vector database files (auto-generated, large) ─────────────────
backend/knowledge/chroma_store/


# ── DATA FOLDERS — Raw images/videos can be huge ────────────────────────────
data/raw/
data/processed/
FilesToIgnore/


# ── JUPYTER NOTEBOOK OUTPUTS — Clutter, not needed in Git ────────────────────
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/


# ── OS GENERATED FILES — Mac/Windows system clutter ──────────────────────────
.DS_Store             # Mac folder metadata
Thumbs.db             # Windows folder thumbnails
desktop.ini           # Windows folder settings


# ── IDE / EDITOR FILES — Personal editor settings, not project files ─────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace



# ── EXPERIMENTS — Generated by experiment.py, not source code ──────────────
experiments/


# ── DOCKER VOLUMES — Auto-generated at runtime ───────────────────────────────
*.volume


# ── LOGS ─────────────────────────────────────────────────────────────────────
*.log
logs/


# ── TEMPORARY / UPLOAD FILES — Runtime uploads, not source code ──────────────
backend/uploads/
frontend/uploads/
*.tmp




